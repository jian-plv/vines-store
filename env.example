# ─── PostgreSQL via Neon ──────────────────────────────────────────────────────
# Get your connection string from: https://console.neon.tech/
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.ap-southeast-1.aws.neon.tech/vines_store?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-strong-random-secret-at-least-32-chars"

# On Vercel this is set automatically. Locally use http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV="development"
