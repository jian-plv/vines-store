{
  "name": "vines-store",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev":         "next dev",
    "build":       "prisma generate && next build",
    "start":       "next start",
    "lint":        "next lint",
    "db:push":     "prisma db push",
    "db:migrate":  "prisma migrate dev",
    "db:studio":   "prisma studio",
    "db:seed":     "tsx prisma/seed.ts",
    "db:reset":    "prisma migrate reset --force && tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "next":          "15.0.4",
    "react":         "^19.0.0",
    "react-dom":     "^19.0.0",
    "next-auth":     "^4.24.11",
    "@prisma/client":"^5.22.0",
    "bcryptjs":      "^2.4.3",
    "lucide-react":  "^0.468.0",
    "recharts":      "^2.13.3",
    "clsx":          "^2.1.1",
    "tailwind-merge":"^2.5.4",
    "date-fns":      "^4.1.0",
    "zod":           "^3.23.8"
  },
  "devDependencies": {
    "typescript":          "^5",
    "@types/node":         "^20",
    "@types/react":        "^19",
    "@types/react-dom":    "^19",
    "@types/bcryptjs":     "^2.4.6",
    "prisma":              "^5.22.0",
    "tailwindcss":         "^3.4.1",
    "postcss":             "^8",
    "autoprefixer":        "^10.0.1",
    "tsx":                 "^4.19.2",
    "eslint":              "^8",
    "eslint-config-next":  "15.0.4"
  }
}
